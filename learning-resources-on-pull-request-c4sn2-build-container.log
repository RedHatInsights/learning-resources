time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] fi"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] + [[ -f ./build-tools/parse-secrets.sh ]]"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] + source ./build-tools/parse-secrets.sh"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] #!/bin/bash"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] "
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] # Script to parse .env secrets file and set environment variables"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] # Expected .env structure: KEY=VALUE (one per line)"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] # Lines starting with # are treated as comments and ignored"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] # Empty lines are ignored"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] "
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] SECRETS_FILE=\"/run/secrets/build-container-additional-secret/secrets\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] ++ SECRETS_FILE=/run/secrets/build-container-additional-secret/secrets"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] "
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] if [ ! -f \"$SECRETS_FILE\" ]; then"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]     echo \"Error: Secrets file not found at $SECRETS_FILE\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr] else"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]     if [ ! -r \"$SECRETS_FILE\" ]; then"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]         echo \"parse-secrets.sh: Warning: Cannot read secrets file at $SECRETS_FILE (permission denied)\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]         echo \"Current file permissions: $(ls -la \"$SECRETS_FILE\" 2>/dev/null || echo 'unable to check')\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]         echo \"parse-secrets.sh: Continuing without parsing secrets...\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]     else"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]         # Parse .env file and export environment variables"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]         while IFS= read -r line || [[ -n \"$line\" ]]; do"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             # Skip empty lines and comments"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             if [[ -z \"$line\" ]] || [[ \"$line\" =~ ^[[:space:]]*# ]]; then"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 continue"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             fi"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             "
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             # Check if line contains = and split into key=value"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]             if [[ \"$line\" =~ ^[^=]+= ]]; then"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 # Extract key and value"
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 key=\"${line%%=*}\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 value=\"${line#*=}\""
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 "
time="2026-06-25T06:10:12Z" level=info msg="buildah [stderr]                 # Remove any leading/trailing whitespace from key"
